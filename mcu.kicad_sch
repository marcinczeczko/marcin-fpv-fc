				(size 1.27 1.27)
				(color 0 0 0 1)
			)
			(justify left top)
		)
		(uuid "5fe3d991-1132-4366-811a-06fcbb1f9d26")
	)
	(text_box "SPI1 - GYRO\nSPI3 - FLASH\nI2C1 - BARO + GPS\nLPUART1 (4.5V) - ELRS\nUART1 (5.0V - DFU Hijack) - RX Only (ESC Tele), TX can be on PAD with RX to get one more extra if no tele\nUART3 (4.5V) - GPS\nUART2 (5.0V - DFU Hijack) - VTX\nUART4 (5.0V - DFU Hijack) - OSD\nUART5 (4.5V or 5.0V) Extra\n"
		(exclude_from_sim no)
